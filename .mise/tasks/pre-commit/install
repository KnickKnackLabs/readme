#!/usr/bin/env bash
#MISE description="Install a git pre-commit hook that keeps README.md in sync"
#USAGE flag "--check" help="Error on stale README instead of rebuilding"
set -e

TARGET_DIR="${CALLER_PWD:-$(cd "$(dirname "${BASH_SOURCE[0]}")/../../.." && pwd)}"
CHECK="${usage_check:-false}"

# Must be inside a git repo
HOOK_DIR=$(git -C "$TARGET_DIR" rev-parse --absolute-git-dir 2>/dev/null)/hooks || {
  echo "Error: not a git repository" >&2
  exit 1
}
HOOK_FILE="$HOOK_DIR/pre-commit"

BEGIN_MARKER="# --- readme pre-commit hook begin ---"
END_MARKER="# --- readme pre-commit hook end ---"

# Check if already installed
if [ -f "$HOOK_FILE" ] && grep -q "$BEGIN_MARKER" "$HOOK_FILE" 2>/dev/null; then
  echo "Hook already installed. Run 'readme pre-commit:remove' first to reinstall."
  exit 0
fi

mkdir -p "$HOOK_DIR"

# Generate the hook block
if [ "$CHECK" = "true" ]; then
  HOOK_BODY='    readme build --check || {
      echo ""
      echo "README.md is out of date. Run '\''readme build'\'' to update it."
      exit 1
    }'
else
  HOOK_BODY='    readme build
    git add README.md'
fi

HOOK_BLOCK="$BEGIN_MARKER
if git diff --cached --name-only | grep -q '^README\\.tsx$'; then
$HOOK_BODY
fi
$END_MARKER"

# Append to existing hook or create new one
if [ -f "$HOOK_FILE" ]; then
  printf '\n%s\n' "$HOOK_BLOCK" >> "$HOOK_FILE"
else
  printf '#!/usr/bin/env bash\n\n%s\n' "$HOOK_BLOCK" > "$HOOK_FILE"
fi

chmod +x "$HOOK_FILE"

if [ "$CHECK" = "true" ]; then
  echo "Installed pre-commit hook (check mode — will error if README.md is stale)"
else
  echo "Installed pre-commit hook (build mode — will rebuild and stage README.md)"
fi
