#!/usr/bin/env bash
#MISE description="Generate README.md from README.tsx"
#USAGE flag "--check" help="Check if README.md is up to date (exit 1 if stale)"
set -e

REPO_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"

if [[ -z "${README_CALLER_PWD:-}" ]]; then
  echo "Error: README_CALLER_PWD is not set." >&2
  echo "readme build must be run through the installed readme shim, or with" >&2
  echo "README_CALLER_PWD set to the directory containing README.tsx, e.g.:" >&2
  echo "  README_CALLER_PWD=\"\$PWD\" mise -C \"$REPO_DIR\" run build --check" >&2
  exit 1
fi

TARGET_DIR="$README_CALLER_PWD"

# Bun's --tsconfig-override is broken for jsxImportSource (oven-sh/bun#22023),
# but it does work for paths. So we split the responsibility:
#   - Each README.tsx uses a /** @jsxImportSource jsx-md */ pragma
#   - This override tsconfig handles module resolution only (paths)
TSCONFIG=$(mktemp)
cat > "$TSCONFIG" <<CONF
{
  "compilerOptions": {
    "paths": {
      "jsx-md/jsx-runtime": ["$REPO_DIR/src/jsx-runtime.ts"],
      "jsx-md/jsx-dev-runtime": ["$REPO_DIR/src/jsx-dev-runtime.ts"],
      "readme": ["$REPO_DIR/index.ts"],
      "readme/*": ["$REPO_DIR/*"]
    }
  }
}
CONF
trap 'rm -f "$TSCONFIG"' EXIT

if [[ ! -f "$TARGET_DIR/README.tsx" ]]; then
  echo "No README.tsx found in $TARGET_DIR"
  exit 1
fi

# Generate markdown from TSX
# Filter the spurious "directory mismatch" warning from oven-sh/bun#22023
output=$(bun run --tsconfig-override "$TSCONFIG" "$TARGET_DIR/README.tsx" 2> >(grep -v "Internal error: directory mismatch" >&2))

if [[ "${usage_check}" == "true" ]]; then
  if [[ ! -f "$TARGET_DIR/README.md" ]]; then
    echo "README.md does not exist. Run 'readme build' to generate it."
    exit 1
  fi

  if ! diff -u "$TARGET_DIR/README.md" <(echo "$output") > /dev/null 2>&1; then
    echo "README.md is out of date. Run 'readme build' to update it."
    echo ""
    diff -u "$TARGET_DIR/README.md" <(echo "$output") || true
    exit 1
  fi

  echo "README.md is up to date."
  exit 0
fi

# Write output, but skip the rewrite when the rendered content already matches.
# This is a content-aware cache (not mtime-based): it avoids needless writes and
# mtime churn without ever masking a stale file, and works for any target dir
# (cross-repo callers included). Caching is kept inside the task — never as mise
# #MISE sources/outputs — so `--check` above always compares content and can
# never be skipped on timestamps.
if [[ -f "$TARGET_DIR/README.md" ]] && diff -q "$TARGET_DIR/README.md" <(echo "$output") > /dev/null 2>&1; then
  echo "README.md already up to date"
else
  echo "$output" > "$TARGET_DIR/README.md"
  echo "Generated README.md"
fi
